#!name=Tasks Module
#!desc=Cron Task Pack
#!system=ios

[Script]
# > 顺丰速运 DailyBonus by chavyleung
Tasks: 顺丰速运 = type=cron,cronexp="12 0 * * *",timeout=120,script-path=https://raw.githubusercontent.com/leafTheFish/DeathNote/main/sfsy.js

# > 达乐美披萨小游戏 DailyBonus by Sliverkiss
Tasks: 达乐美小游戏 = type=cron,cronexp="13 0 * * *",timeout=300,script-path=https://gist.githubusercontent.com/Sliverkiss/6b4da0d367d13790a9fd1d928c82bdf8/raw/dlm.js

# > 阿里云盘 DailyBonus by lowking
Tasks: 阿里云盘 = type=cron,cronexp="14 0 * * *",script-path=https://raw.githubusercontent.com/lowking/Scripts/master/ali/aliYunPanCheckIn.js,timeout=60, wake-system=1

# > 霸王茶姬小程序 DailyBonus by Guding88
Tasks: 霸王茶姬小程序签到 = type=cron,cronexp=00 00 10 * * *,script-path=https://raw.githubusercontent.com/Guding88/Script/main/bawangchaji/bwcj.js,script-update-interval=0
Tasks: 霸王茶姬小程序签到2024 = type=cron,cronexp=02 00 10 * * *,script-path=https://raw.githubusercontent.com/Guding88/Script/main/bawangchaji/bwcj2024.js,script-update-interval=0

# > 龙湖天街
Tasks: 龙湖天街 = type=cron,cronexp="15 0 * * *",timeout=300,script-path=https://raw.githubusercontent.com/leiyiyan/resource/main/script/lhtj/lhtj.js
